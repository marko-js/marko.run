
import type { RouteFile } from "app/routes/repl/util/routes";

export interface Input {
  layouts: RouteFile[];
  page: RouteFile;
  depth: number;
  colors: Map<RouteFile, string>;
  highlightedFile: RouteFile | null;
  highlightedFileChange: (file: RouteFile | null) => void;
}

const/{ layouts, depth, page, ...rest }=input

if=depth < layouts.length
  file ...rest file=layouts[depth]
    layout-file ...rest layouts=layouts depth=depth + 1 page=page
else
  file ...rest file=page
